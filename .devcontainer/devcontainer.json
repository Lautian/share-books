{
    "name": "share-books",
    "image": "mcr.microsoft.com/devcontainers/python:3.12",
    "postCreateCommand": "pip install -r requirements.txt && python manage.py migrate",
    "forwardPorts": [8000],
    "portsAttributes": {
        "8000": {
            "label": "Django dev server",
            "onAutoForward": "notify"
        }
    }
}
